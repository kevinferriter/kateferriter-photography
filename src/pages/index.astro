---
import LandingLayout from '../layouts/LandingLayout.astro';
---

<LandingLayout title="Photography Portfolio">
  <!-- Hero Section -->
  <section class="relative w-full h-[60vh] md:h-[75vh] overflow-hidden">
    <img
      src="/images/hero/hero.jpg"
      alt="Featured Photography"
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-black/40 flex items-center justify-center">
      <h1 class="text-white text-4xl md:text-6xl font-semibold text-center px-4">
        Capturing Moments, Stories, and Light
      </h1>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="max-w-3xl mx-auto py-12 px-4 text-center">
    <p class="text-lg text-gray-700">
      Welcome to my photography portfolio. I explore portraits, nature, and creative
      storytelling through the lens. Here are a few featured projects — click to view
      the full galleries.
    </p>
  </section>

  <!-- Featured Projects -->
  <section class="max-w-6xl mx-auto py-12 px-4">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-10">
      <!-- Nature Study -->
      <a href="/portfolio/nature-study" class="block group">
        <img
          src="/images/portfolio/nature-study/cover.jpg"
          alt="Nature Study Cover"
          class="rounded-xl shadow-md group-hover:opacity-90 transition"
        />
        <h2 class="mt-4 text-xl font-medium text-center">Nature Study</h2>
      </a>

      <!-- Urban Portraits -->
      <a href="/portfolio/urban-portraits" class="block group">
        <img
          src="/images/portfolio/urban-portraits/cover.jpg"
          alt="Urban Portraits Cover"
          class="rounded-xl shadow-md group-hover:opacity-90 transition"
        />
        <h2 class="mt-4 text-xl font-medium text-center">Urban Portraits</h2>
      </a>
    </div>
  </section>
</LandingLayout>
