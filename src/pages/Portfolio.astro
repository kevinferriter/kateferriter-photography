---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="Portfolio">
  <section class="max-w-5xl mx-auto py-12">
    <h1 class="text-4xl font-semibold mb-6">Portfolio</h1>
    <p class="text-lg mb-10 text-gray-600">
      A selection of photography projects. Click any project to view the full gallery.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
      <!-- Urban Portraits -->
      <a href="/portfolio/urban-portraits" class="block group">
        <img
          src="/images/portfolio/urban-portraits/cover.jpg"
          alt="Urban Portaits Cover"
          class="rounded-xl shadow-md group-hover:opacity-90 transition"
        />
        <h2 class="mt-3 text-lg font-medium">Project One</h2>
      </a>

      <!-- Nature Study -->
      <a href="/portfolio/nature-study" class="block group">
        <img
          src="/images/portfolio/nature-study/cover.jpg"
          alt="Nature Study Cover"
          class="rounded-xl shadow-md group-hover:opacity-90 transition"
        />
        <h2 class="mt-3 text-lg font-medium">Project Two</h2>
      </a>
    </div>
  </section>
</PageLayout>
